# slotplate runtime knobs — copy to .env.local and edit.
# Vite exposes any var prefixed with VITE_ to client code.

# Which transport to use: mock | http | ws
# - mock: offline fake server (default; what `pnpm dev` uses out of the box)
# - http: POSTs /session and /spin against VITE_API_URL
# - ws:   request/response over a single WebSocket at VITE_WS_URL
VITE_NETWORK=mock

# Required when VITE_NETWORK=http
VITE_API_URL=https://rgs.example.com/api

# Required when VITE_NETWORK=ws
VITE_WS_URL=wss://rgs.example.com/ws

# Optional — lobby-supplied auth, forwarded as Authorization: Bearer <token>
# Lobby integrations usually pass these via the URL (?token=... or ?sessionToken=...).
VITE_AUTH_TOKEN=

# Optional — free-form operator/lobby id forwarded to the server.
VITE_LOBBY_ID=
