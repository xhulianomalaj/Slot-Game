{
  "name": "my-slot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:screenshots": "playwright test",
    "test:screenshots:update": "playwright test --update-snapshots",
    "test:e2e": "playwright test --config=playwright.scenarios.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.scenarios.config.ts --ui",
    "test:e2e:debug": "playwright test --config=playwright.scenarios.config.ts --debug",
    "test:catalog": "node ./scripts/generate-scenario-catalog.mjs",
    "test:components": "node ./scripts/generate-components-catalog.mjs",
    "test:import-log": "node ./scripts/import-server-log.mjs",
    "test:contract": "vitest run tests/contract",
    "assets:pack": "assetpack",
    "assets:watch": "assetpack -w",
    "assets:generate": "node ./scripts/generate-assets.mjs",
    "assets:theme": "node ./scripts/generate-theme.mjs"
  },
  "dependencies": {
    "@fontsource/roboto-condensed": "^5.2.0",
    "gsap": "^3.13.0",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.1.0",
    "pixi-reels": "^0.1.0",
    "pixi.js": "^8.11.0",
    "preact": "^10.26.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@playwright/test": "^1.50.0",
    "@assetpack/cli": "^0.8.0",
    "@assetpack/core": "^1.7.0",
    "@preact/preset-vite": "^2.10.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "@esotericsoftware/spine-pixi-v8": {
      "optional": true
    }
  }
}
